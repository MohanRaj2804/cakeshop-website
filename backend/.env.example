# Server Port
PORT=5000

# MongoDB Connection String
# For local MongoDB: mongodb://127.0.0.1:27017/cakeshop
# For MongoDB Atlas (cloud): mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb://127.0.0.1:27017/cakeshop

# JWT Secret Key (change this to a random string in production)
JWT_SECRET=your_secret_key_change_this_in_production

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173
